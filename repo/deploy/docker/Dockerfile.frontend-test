# Dedicated frontend E2E test image. Based on the official Playwright image,
# which ships Node.js AND the browser binaries + system libraries required for
# Chromium/Firefox/WebKit — so `npx playwright test` can run headlessly inside
# docker-compose without any extra apt-get installs.
FROM mcr.microsoft.com/playwright:v1.44.1-jammy

WORKDIR /app

COPY frontend/package*.json ./
RUN npm ci --no-audit --no-fund

COPY frontend/ .

# Default command is real Playwright. Exit code drives CI pass/fail.
CMD ["npx", "playwright", "test"]
