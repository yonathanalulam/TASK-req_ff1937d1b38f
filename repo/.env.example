# ─── Database ────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=rootpassword
DB_NAME=service_portal
DB_USER=portal_user
DB_PASSWORD=portalpassword
DB_HOST=db
DB_PORT=3306
DB_TEST_NAME=service_portal_test

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
PORT=8080
SESSION_COOKIE_DOMAIN=localhost

# ─── Security ────────────────────────────────────────────────────────────────
# Must be exactly 32 bytes (256-bit) hex-encoded key for AES-256.
#
# !!! DO NOT USE THIS VALUE IN PRODUCTION !!!
# The value below is a well-known placeholder committed to the public repo.
# The backend refuses to start with this value when APP_ENV=production.
# Generate a fresh key per environment with:
#     ./scripts/gen-key.sh          # or: openssl rand -hex 32
FIELD_ENCRYPTION_KEY=1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef


# ─── TLS (MANDATORY in all environments — no HTTP fallback) ──────────────────
# Both paths must point at readable PEM files; the backend fails fast on
# startup if either is missing. Run ./scripts/gen-tls-cert.sh to produce a
# self-signed pair at the default paths below for local development/testing.
# In production, replace with a cert from your CA.
TLS_CERT_FILE=/app/storage/tls/dev.crt
TLS_KEY_FILE=/app/storage/tls/dev.key

# ─── Frontend ────────────────────────────────────────────────────────────────
# Empty → SPA uses relative /api paths, proxied by nginx to the TLS backend
# on the docker network (avoids CORS + self-signed cert trust issues).
VITE_API_BASE_URL=
FRONTEND_PORT=5173
BACKEND_PORT=8080
